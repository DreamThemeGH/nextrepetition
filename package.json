{
    "name": "nextcloud-flashcards",
    "version": "2.0.2",
    "description": "Nextcloud Flashcards v2 — File-based spaced repetition for language learning",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite build --mode development",
        "watch": "vite build --watch --mode development",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@nextcloud/auth": "^2.5.3",
        "@nextcloud/axios": "^2.5.0",
        "@nextcloud/dialogs": "^7.0.0",
        "@nextcloud/initial-state": "^3.0.0",
        "@nextcloud/l10n": "^3.1.0",
        "@nextcloud/router": "^3.0.0",
        "@nextcloud/vue": "^9.0.0",
        "chart.js": "^4.5.1",
        "pinia": "^2.1.7",
        "vue": "^3.4.0",
        "vue-chartjs": "^5.3.3",
        "vue-material-design-icons": "^3.4.0",
        "vue-router": "^4.2.5"
    },
    "devDependencies": {
        "@nextcloud/browserslist-config": "^3.0.1",
        "@nextcloud/eslint-config": "^8.4.1",
        "@nextcloud/vite-config": "^1.4.0",
        "@types/node": "^20.11.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/test-utils": "^2.4.4",
        "@vue/tsconfig": "^0.7.0",
        "eslint": "^8.57.0",
        "happy-dom": "^17.0.0",
        "sass": "^1.71.0",
        "typescript": "^5.3.3",
        "vite": "^7.1.10",
        "vitest": "^3.0.0",
        "vue-tsc": "^3.0.0"
    },
    "browserslist": [
        "extends @nextcloud/browserslist-config"
    ]
}
